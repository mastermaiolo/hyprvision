#!/usr/bin/env python3
"""
HyprVision v4 · Daemon adaptativo
  Lê toda a configuração de daemon_config.toml (hot-reload via SIGHUP).

  Estados de energia:
    PLUGGED   — carregador ligado              → perfil: battery.plugged
    UNPLUGGED — desconectou, bateria ok        → perfil: battery.unplugged
    LOW       — bateria abaixo do threshold    → perfil: battery.low
    DESKTOP   — sem bateria (desktop)          → sem alteração
  Qualquer perfil pode ser "none" = não fazer nada nesse evento.
  Com restore_after_low, ao sair de LOW volta ao perfil anterior.

  Horários:
    Aplica o perfil de um slot apenas quando a hora CRUZA o limite do
    slot com o daemon a correr. No arranque respeita o perfil actual
    (a não ser que schedule.apply_on_start = true).

  Sinais:
    SIGHUP  — relê o daemon_config.toml sem reiniciar o processo.
    SIGTERM — termina limpo (remove o PID file).

  Persistência visual:
    Um config reload do Hyprland (theming, hyprctl reload) limpa os
    keywords screen_shader e monitor/icc. O daemon escuta o evento
    `configreloaded` no socket2 do Hyprland e reaplica os visuais;
    como fallback, cada ciclo verifica se o shader esperado caiu.

  Robustez:
    Uma falha ao aplicar um perfil NUNCA mata o daemon — é registada
    em state/daemon.log e o loop continua.
"""
import datetime
import os
import signal
import socket
import subprocess
import sys
import threading
import time

sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), "..")))

from core import daemonctl
from core.apply  import ApplyPipeline
from core.config import load as load_config, profile_action, DaemonConfig, ScheduleSlot
from core.notify import notify

BASE_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))
LOG_FILE = os.path.join(BASE_DIR, "state", "daemon.log")
LOG_MAX_BYTES = 256 * 1024

LOOP_INTERVAL_SEC = 30


def log(msg: str) -> None:
    line = f"{datetime.datetime.now():%Y-%m-%d %H:%M:%S} {msg}"
    print(f"[HyprVision Daemon] {msg}")
    try:
        if os.path.isfile(LOG_FILE) and os.path.getsize(LOG_FILE) > LOG_MAX_BYTES:
            os.replace(LOG_FILE, LOG_FILE + ".old")
        with open(LOG_FILE, "a", encoding="utf-8") as f:
            f.write(line + "\n")
    except OSError:
        pass


# ── Hardware ──────────────────────────────────────────────────────────

def battery_level() -> int:
    """Retorna % da bateria, ou -1 se não existir bateria (desktop)."""
    try:
        for bat in sorted(os.listdir("/sys/class/power_supply/")):
            if bat.startswith("BAT"):
                with open(f"/sys/class/power_supply/{bat}/capacity") as f:
                    return int(f.read().strip())
    except (OSError, ValueError):
        pass
    return -1


def power_status() -> str:
    try:
        for bat in sorted(os.listdir("/sys/class/power_supply/")):
            if bat.startswith("BAT"):
                with open(f"/sys/class/power_supply/{bat}/status") as f:
                    return f.read().strip().lower()
    except OSError:
        pass
    return "unknown"


def get_power_state(cap: int, status: str, threshold: int) -> str:
    if cap == -1:
        return "desktop"
    if status in ("charging", "full"):
        return "plugged"
    if cap < threshold:
        return "low"
    return "unplugged"


# ── Eventos do Hyprland (socket2) ─────────────────────────────────────

def hypr_event_socket() -> str | None:
    sig     = os.environ.get("HYPRLAND_INSTANCE_SIGNATURE")
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if not sig or not runtime:
        return None
    path = os.path.join(runtime, "hypr", sig, ".socket2.sock")
    return path if os.path.exists(path) else None


def shader_keyword_active() -> bool | None:
    """True/False se o keyword screen_shader está definido; None se não deu
    para perguntar (Hyprland indisponível)."""
    try:
        r = subprocess.run(
            ["hyprctl", "getoption", "decoration:screen_shader"],
            capture_output=True, text=True, timeout=3
        )
        if r.returncode != 0:
            return None
        return "set: true" in r.stdout
    except Exception:
        return None


# ── Horários ──────────────────────────────────────────────────────────

def current_schedule_slot(cfg: DaemonConfig) -> ScheduleSlot | None:
    """
    Devolve o slot de horário activo neste momento, ou None.
    O slot activo é o último cujo horário <= agora (wrap à meia-noite).
    """
    if not cfg.schedule.enabled:
        return None

    active_slots = sorted(
        [s for s in cfg.schedule.slots if s.enabled and profile_action(s.profile)],
        key=lambda s: s.minutes_of_day,
    )
    if not active_slots:
        return None

    now = datetime.datetime.now()
    now_min = now.hour * 60 + now.minute
    chosen = None
    for slot in active_slots:
        if slot.minutes_of_day <= now_min:
            chosen = slot
    # Wrap: se nenhum passou ainda hoje, vale o último slot do dia anterior
    if chosen is None:
        chosen = active_slots[-1]
    return chosen


# ── Main ──────────────────────────────────────────────────────────────

class Daemon:
    def __init__(self):
        self.pipeline = ApplyPipeline(BASE_DIR)
        self.cfg: DaemonConfig = load_config()
        self.reload_pending  = False
        self.stop_requested  = False
        self.reapply_pending = False   # Hyprland fez config reload

        self.prev_power: str | None = None
        self.prev_slot:  str | None = None   # nome do slot, não o perfil
        # Perfil activo antes de entrarmos em modo bateria-baixa
        self.pre_low_profile: str | None = None

    # ── Sinais ────────────────────────────────────────────────────────
    def handle_sighup(self, signum, frame):
        self.reload_pending = True

    def handle_sigterm(self, signum, frame):
        self.stop_requested = True

    # ── Eventos do Hyprland ───────────────────────────────────────────
    def watch_hyprland_events(self) -> None:
        """
        Thread: escuta o socket2 do Hyprland e marca reapply_pending
        quando há um `configreloaded`. Reconecta se a ligação cair
        (ex.: Hyprland reiniciado); desiste só quando o daemon pára.
        """
        while not self.stop_requested:
            path = hypr_event_socket()
            if not path:
                time.sleep(10)
                continue
            try:
                with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as s:
                    s.connect(path)
                    s.settimeout(2)
                    buf = b""
                    while not self.stop_requested:
                        try:
                            chunk = s.recv(4096)
                        except socket.timeout:
                            continue
                        if not chunk:
                            break   # socket fechado — reconecta
                        buf += chunk
                        while b"\n" in buf:
                            line, buf = buf.split(b"\n", 1)
                            if line.startswith(b"configreloaded"):
                                self.reapply_pending = True
            except OSError:
                pass
            time.sleep(2)

    def maybe_reapply_visuals(self, reason: str) -> None:
        """Reaplica shader/ICC se o estado espera algum efeito visual."""
        state = self.pipeline.state_mgr.read_state()
        expects_visuals = bool(
            state.shader or state.extra_shader or state.icc
            or state.overlay.paper_texture != "off"
            or state.overlay.dim_level > 0
        )
        if not expects_visuals:
            return
        if self.pipeline.reapply_visuals():
            log(f"visuais reaplicados ({reason})")
        else:
            log(f"falha ao reaplicar visuais ({reason})")

    # ── Aplicação protegida ───────────────────────────────────────────
    def apply(self, profile_id: str, reason: str) -> bool:
        """Aplica um perfil sem nunca propagar excepções para o loop."""
        try:
            ok = self.pipeline.apply_profile(profile_id)
            if not ok:
                log(f"falha ao aplicar '{profile_id}' ({reason})")
            return ok
        except Exception as e:
            log(f"erro inesperado ao aplicar '{profile_id}' ({reason}): {e}")
            return False

    # ── Bateria ───────────────────────────────────────────────────────
    def check_battery(self) -> str:
        cap    = battery_level()
        status = power_status()
        power  = get_power_state(cap, status, self.cfg.battery.threshold)

        if not self.cfg.battery.enabled or power == self.prev_power:
            self.prev_power = power
            return power

        first_check = self.prev_power is None
        leaving_low = self.prev_power == "low"
        self.prev_power = power

        # No arranque só estabelece a baseline — não mexe no ecrã.
        if first_check:
            return power

        if power == "low":
            prof = profile_action(self.cfg.battery.low)
            if prof:
                # Memoriza o perfil actual para repor na recuperação
                self.pre_low_profile = \
                    self.pipeline.state_mgr.read_state().active_profile
                notify("HyprVision Adaptive",
                       f"⚠️ Bateria baixa ({cap}%) → {prof}", "critical")
                self.apply(prof, "bateria baixa")
            return power

        # A sair de "low" — repõe o perfil anterior se configurado
        if leaving_low and self.cfg.battery.restore_after_low \
                and self.pre_low_profile:
            prof = self.pre_low_profile
            self.pre_low_profile = None
            notify("HyprVision Adaptive", f"🔋 Bateria recuperada → {prof}")
            self.apply(prof, "recuperação de bateria")
            return power

        if power == "plugged":
            prof = profile_action(self.cfg.battery.plugged)
            if prof:
                notify("HyprVision Adaptive", f"🔌 Carregador ligado → {prof}")
                self.apply(prof, "carregador ligado")
        elif power == "unplugged":
            prof = profile_action(self.cfg.battery.unplugged)
            if prof:
                notify("HyprVision Adaptive", f"🔋 Desconectado ({cap}%) → {prof}")
                self.apply(prof, "carregador desligado")
        return power

    # ── Horário ───────────────────────────────────────────────────────
    def check_schedule(self, apply_now: bool) -> None:
        slot = current_schedule_slot(self.cfg)
        if slot is None:
            self.prev_slot = None
            return

        if slot.name == self.prev_slot:
            return

        first_check = self.prev_slot is None
        self.prev_slot = slot.name

        # No arranque só regista o slot actual — não sobrepõe o perfil
        # escolhido manualmente (a não ser que apply_on_start = true).
        if first_check and not apply_now:
            return

        prof = profile_action(slot.profile)
        if prof:
            notify("HyprVision Adaptive", f"🕐 Horário ({slot.name}) → {prof}")
            self.apply(prof, f"horário {slot.name}")

    # ── Loop ──────────────────────────────────────────────────────────
    def run(self) -> None:
        # Instância única
        existing = daemonctl.running_pid(BASE_DIR)
        if existing and existing != os.getpid():
            print(f"[HyprVision Daemon] Já a correr (PID {existing}). A sair.")
            sys.exit(0)

        signal.signal(signal.SIGHUP,  self.handle_sighup)
        signal.signal(signal.SIGTERM, self.handle_sigterm)

        daemonctl.write_pid(BASE_DIR)
        log("iniciado")
        notify("HyprVision", "Daemon iniciado ✓")

        threading.Thread(target=self.watch_hyprland_events, daemon=True).start()

        apply_on_start = self.cfg.schedule.apply_on_start

        try:
            while not self.stop_requested:
                try:
                    if self.reapply_pending:
                        self.reapply_pending = False
                        # Pequena pausa: deixa o reload do Hyprland assentar
                        time.sleep(0.5)
                        self.maybe_reapply_visuals("configreloaded")

                    if self.reload_pending:
                        self.reload_pending = False
                        self.cfg = load_config()
                        # Reavalia transições com a nova config, mas sem
                        # reaplicar o estado actual no próprio reload.
                        self.prev_power = None
                        self.prev_slot  = None
                        apply_on_start  = False
                        notify("HyprVision", "Configuração recarregada ✓")
                        log("config recarregada (SIGHUP)")

                    if self.cfg.enabled:
                        power = self.check_battery()
                        # Horário não interfere durante bateria crítica
                        if power != "low":
                            self.check_schedule(apply_on_start)
                        apply_on_start = False

                    # Fallback ao evento: se o estado espera um shader mas
                    # o keyword caiu (reload perdido), reaplica.
                    state = self.pipeline.state_mgr.read_state()
                    if (state.shader or state.extra_shader) \
                            and shader_keyword_active() is False:
                        self.maybe_reapply_visuals("shader caiu")

                except Exception as e:
                    # Nada derruba o daemon — regista e continua
                    log(f"erro no ciclo: {e}")

                # Sleep interrompível para reagir rápido a SIGTERM/eventos
                for _ in range(LOOP_INTERVAL_SEC):
                    if self.stop_requested or self.reload_pending \
                            or self.reapply_pending:
                        break
                    time.sleep(1)

        except KeyboardInterrupt:
            pass
        finally:
            daemonctl.clear_pid(BASE_DIR)
            log("terminado")


if __name__ == "__main__":
    Daemon().run()

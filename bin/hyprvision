#!/usr/bin/env python3
"""HyprVision v4 — CLI principal."""
import argparse
import os
import subprocess
import sys

sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), "..")))

from core import daemonctl
from core.apply  import ApplyPipeline
from core.config import load as load_config, ensure_full_config, CONFIG_PATH
from core.profile import ProfileLoader
from core.shader import PAPER_INTENSITY

BASE_DIR = os.path.abspath(os.path.join(os.path.dirname(__file__), ".."))


def _apply_keybinds_live(keybinds: dict) -> bool:
    """
    Aplica keybinds imediatamente ao Hyprland em runtime via hyprctl eval
    (que executa Lua no compositor, sem precisar reiniciar).
    Só funciona dentro de sessão Hyprland.
    """
    if not os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"):
        return False

    action_cmds = {
        "menu": f"{BASE_DIR}/ui/launcher.sh",
    }

    lua_lines = []
    for action_id, entry in keybinds.items():
        cmd = action_cmds.get(action_id)
        if not cmd:
            continue
        combo = " + ".join(entry.mods.split() + [entry.key])
        lua_lines.append(f'hl.bind("{combo}", hl.dsp.exec_cmd("{cmd}"))')

    if not lua_lines:
        return False

    try:
        r = subprocess.run(
            ["hyprctl", "eval", "; ".join(lua_lines)],
            capture_output=True, text=True, timeout=3
        )
        return r.returncode == 0
    except Exception:
        return False


def _exit(ok: bool) -> None:
    sys.exit(0 if ok else 1)


def main() -> None:
    p = argparse.ArgumentParser(
        description="HyprVision v4 — Gestor Modular de Ergonomia Visual",
        formatter_class=argparse.RawTextHelpFormatter,
    )

    p.add_argument("--apply",        metavar="ID",   help="Aplica um perfil pelo ID")
    p.add_argument("--apply-extra",  metavar="FILE",
                   help="Aplica um shader extra (nome em shaders/extras ou path)")
    p.add_argument("--safe-reset",   action="store_true", help="Reset de emergência")
    p.add_argument("--restore",      action="store_true", help="Restaura estado após reinício")
    p.add_argument("--status",       action="store_true", help="Mostra estado actual")
    p.add_argument("--list-rofi",    action="store_true", help="Lista perfis para Rofi/Fuzzel")

    # Daemon
    p.add_argument("--daemon-start",  action="store_true", help="Arranca o daemon")
    p.add_argument("--daemon-stop",   action="store_true", help="Pára o daemon")
    p.add_argument("--reload-daemon", action="store_true",
                   help="Envia SIGHUP ao daemon para reler daemon_config.toml")
    p.add_argument("--init-config",   action="store_true",
                   help="Cria/completa o daemon_config.toml com todas as opções")

    # Overlays
    p.add_argument("--paper-texture", metavar="LEVEL",
                   choices=list(PAPER_INTENSITY.keys()),
                   help="Overlay de textura de papel (off|light|medium|heavy)")
    p.add_argument("--dim", metavar="N", type=int,
                   choices=[0, 10, 20, 30, 40, 50],
                   help="Extra Dim em %% (0=desligado)")

    args = p.parse_args()
    pipeline = ApplyPipeline(BASE_DIR)

    # ── Daemon ─────────────────────────────────────────────────────────
    if args.daemon_start:
        pid = daemonctl.start(BASE_DIR)
        if pid:
            print(f"[HyprVision] Daemon a correr (PID {pid}).")
        else:
            print("[HyprVision] Falha ao arrancar o daemon.", file=sys.stderr)
        _exit(pid is not None)

    if args.daemon_stop:
        ok = daemonctl.stop(BASE_DIR)
        print("[HyprVision] Daemon parado." if ok
              else "[HyprVision] Daemon não respondeu ao SIGTERM.")
        _exit(ok)

    if args.reload_daemon:
        if not daemonctl.reload(BASE_DIR):
            print("[HyprVision] Daemon não está a correr.")
            _exit(False)
        print("[HyprVision] SIGHUP enviado ao daemon.")
        # Também aplica keybinds actualizados ao Hyprland em live
        cfg = load_config()
        if cfg.keybinds:
            if _apply_keybinds_live(cfg.keybinds):
                print("[HyprVision] Keybinds actualizados no Hyprland.")
            else:
                print("[HyprVision] Keybinds actualizados no próximo reinício.")
        _exit(True)

    if args.init_config:
        created = ensure_full_config()
        print(f"[HyprVision] Config {'criada/completada' if created else 'já completa'}: "
              f"{CONFIG_PATH}")
        _exit(True)

    # ── Acções principais ──────────────────────────────────────────────
    if args.safe_reset:
        _exit(pipeline.safe_reset())

    if args.restore:
        _exit(pipeline.restore())

    if args.status:
        state = pipeline.state_mgr.read_state()
        print(f"Perfil     : {state.active_profile}")
        print(f"Temperatura: {state.temperature}K")
        print(f"Brightness : {state.brightness}")
        print(f"Gamma      : {state.gamma}")
        print(f"Shader     : {state.shader or '(nenhum)'}")
        print(f"Extra      : {os.path.basename(state.extra_shader) or '(nenhum)'}")
        print(f"ICC        : {state.icc or '(nenhum)'}")
        print(f"Paper Tex  : {state.overlay.paper_texture}")
        print(f"Dim        : {state.overlay.dim_level}%")
        pid = daemonctl.running_pid(BASE_DIR)
        print(f"Daemon     : {'a correr (PID ' + str(pid) + ')' if pid else 'parado'}")
        print(f"Config     : {CONFIG_PATH}")
        sys.exit(0)

    if args.list_rofi:
        # Menu principal: perfis por categoria + entradas de submenu.
        # Saída com pango markup (launcher passa -markup-rows ao rofi);
        # os separadores e os [ids] ficam esbatidos, o resto legível.
        def sep(label):
            print(f"<span alpha='55%' style='italic'>──  {label}  ──</span>")

        def row(icon, text, rid, mark=False):
            m = "  ✓" if mark else ""
            print(f"{icon} {text}{m}   <span alpha='30%' size='small'>[{rid}]</span>")

        loader   = ProfileLoader(os.path.join(BASE_DIR, "profiles"))
        profiles = loader.load_all_profiles()
        order    = {"correction": 0, "experience": 1, "system": 2}
        profiles.sort(key=lambda pr: (order.get(pr.category, 9), pr.name))

        state = pipeline.state_mgr.read_state()

        last_cat = None
        for pr in profiles:
            if pr.category != last_cat:
                sep({"correction": "🔧 CORRECTION",
                     "experience": "🎭 EXPERIENCE",
                     "system":     "⚙️  SYSTEM"}.get(pr.category, pr.category.upper()))
                last_cat = pr.category
            row(pr.icon, pr.name, pr.id,
                mark=(state.active_profile == pr.id and not state.extra_shader))

        sep("🧩 OVERLAYS · EXTRAS · DAEMON")
        row("📄", f"Paper Texture: {state.overlay.paper_texture}  ▸", "__paper__",
            mark=(state.overlay.paper_texture != "off"))
        row("🔅", f"Extra Dim: {state.overlay.dim_level}%  ▸", "__dim__",
            mark=(state.overlay.dim_level > 0))
        extra = os.path.basename(state.extra_shader)
        row("🌐", f"Shaders extra{': ' + extra if extra else ''}  ▸", "__extras__",
            mark=bool(extra))
        pid = daemonctl.running_pid(BASE_DIR)
        row("⚙️", f"Daemon: {'a correr' if pid else 'parado'}  ▸", "__daemon__")
        sys.exit(0)

    if args.apply:
        _exit(pipeline.apply_profile(args.apply))

    if args.apply_extra:
        _exit(pipeline.apply_extra(args.apply_extra))

    if args.paper_texture is not None or args.dim is not None:
        _exit(pipeline.set_overlay(
            paper_texture = args.paper_texture,
            dim_level     = args.dim,
        ))

    p.print_help()


if __name__ == "__main__":
    main()
